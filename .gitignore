# Raw map downloads (5+ GB, re-downloadable via downloader.py)
data/raw/

# Trained model binaries (regenerate with src/models/baseline.py + tune.py + export_onnx.py)
models/baseline_models/*.pkl
models/*.pkl
models/tuned/*.pkl

