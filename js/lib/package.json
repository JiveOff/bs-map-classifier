{
  "name": "bs-map-classifier",
  "version": "0.1.0",
  "description": "Classify Beat Saber maps into Tech / Speed / Accuracy / Standard / Extreme using an ONNX model trained on note-level pattern features. Works in Node.js and browser.",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "verify": "node verify_parity.js",
    "test": "node --test tests/*.test.js"
  },
  "main": "dist/cjs/index.js",
  "module": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "node":    {
        "import":  { "types": "./types/index.d.ts",    "default": "./src/index.node.js" },
        "require": { "types": "./dist/cjs/index.d.ts", "default": "./dist/cjs/index.js" }
      },
      "browser": { "types": "./types/index.d.ts",      "default": "./src/index.browser.js" },
      "import":  { "types": "./types/index.d.ts",      "default": "./src/index.js" },
      "require": { "types": "./dist/cjs/index.d.ts",   "default": "./dist/cjs/index.js" }
    },
    "./parser": {
      "import":  { "types": "./types/index.d.ts",      "default": "./src/parser.js" },
      "require": { "types": "./dist/cjs/index.d.ts",   "default": "./dist/cjs/parser.js" }
    },
    "./features": {
      "import":  { "types": "./types/index.d.ts",      "default": "./src/features.js" },
      "require": { "types": "./dist/cjs/index.d.ts",   "default": "./dist/cjs/features.js" }
    },
    "./classify": {
      "node":    {
        "import":  { "types": "./types/index.d.ts",    "default": "./src/classify.node.js" },
        "require": { "types": "./dist/cjs/index.d.ts", "default": "./dist/cjs/classify.node.js" }
      },
      "browser": { "types": "./types/index.d.ts",      "default": "./src/classify.browser.js" },
      "import":  { "types": "./types/index.d.ts",      "default": "./src/classify.js" },
      "require": { "types": "./dist/cjs/index.d.ts",   "default": "./dist/cjs/classify.node.js" }
    },
    "./embedded": {
      "import":  { "types": "./types/index.d.ts",      "default": "./dist/embedded.mjs" },
      "require": { "types": "./dist/cjs/embedded.d.ts","default": "./dist/cjs/embedded.js" }
    }
  },
  "browser": {
    "node:fs/promises": false
  },
  "files": [
    "src/",
    "models/",
    "types/",
    "dist/",
    "README.md"
  ],
  "keywords": [
    "beat-saber",
    "ml",
    "classifier",
    "onnx",
    "rhythm-game",
    "pattern-detection"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JiveOff/bs-map-classifier"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "onnxruntime-node": ">=1.17.0",
    "onnxruntime-web": ">=1.17.0"
  },
  "peerDependenciesMeta": {
    "onnxruntime-node": {
      "optional": true
    },
    "onnxruntime-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
